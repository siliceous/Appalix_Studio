{
  "name": "saas-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/adapters/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/db/src/types.ts"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "ajv": "^8",
    "react": "19.1.0"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "expo-auth-session": "^55.0.9",
    "expo-crypto": "^55.0.10",
    "react-native-worklets": "^0.8.1"
  }
}
