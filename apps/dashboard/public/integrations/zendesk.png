    <script type="5a26d9c151509a424dfc2f05-text/javascript">
document.addEventListener('alpine:init', () => {
  // lee preferencia guardada; por defecto abierto en desktop y cerrado en móvil
  const saved = localStorage.getItem('filters.visible');
  const isDesktop = window.matchMedia('(min-width:1024px)').matches;
  Alpine.store('filters', {
    visible: saved === null ? isDesktop : (saved === 'true')
  });
});
</script>



