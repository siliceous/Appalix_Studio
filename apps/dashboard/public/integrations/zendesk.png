    >
        <div class="flex items-center gap-3">
            <span id="top-message-text" class="text-sm leading-5"></span>
            <button id="top-message-close" type="button" aria-label="Close" class="ml-auto inline-flex items-center justify-center rounded-md p-2 text-current/70 hover:text-current hover:bg-black/5 focus:outline-none focus:ring-2 focus:ring-slate-300" onclick="if (!window.__cfRLUnblockHandlers) return false; document.getElementById('top-message').classList.add('hidden')" data-cf-modified-5a26d9c151509a424dfc2f05-="">
                ✕
            </button>
        </div>
    </div>
    <script type="5a26d9c151509a424dfc2f05-text/javascript">
      (function () {
        window.showTopMessage = function (message, type = 'success', ms = 2000) {
          const box = document.getElementById('top-message');
          const text = document.getElementById('top-message-text');
          if (!box || !text) return false;

          const unifiedTone = ['border-slate-300', 'bg-slate-800', 'text-white'];
          const toneMap = {
            success: unifiedTone,
            info: unifiedTone,
            warning: unifiedTone,
            error: unifiedTone,
          };
          const allToneClasses = [
            'border-slate-300', 'bg-slate-800', 'text-white',
            'bg-white', 'text-slate-800',
            'border-amber-300', 'bg-amber-50', 'text-amber-900',
            'border-rose-300', 'bg-rose-50', 'text-rose-900',
          ];
          const safeType = Object.prototype.hasOwnProperty.call(toneMap, type) ? type : 'success';
          box.classList.remove(...allToneClasses);
          box.classList.add(...toneMap[safeType]);

          text.textContent = String(message || '');
          box.classList.remove('hidden', 'opacity-0');
          box.classList.add('opacity-100');

          clearTimeout(box._tmr);
          const delay = Math.max(1000, Number(ms) || 0);
          box._tmr = setTimeout(() => {
            box.classList.remove('opacity-100');
            box.classList.add('opacity-0');
            setTimeout(() => box.classList.add('hidden'), 220);
          }, delay);
          return true;
        };

              })();
    </script>
        <!-- Overlay + Modal Container -->
<div x-cloak
  x-data="{ showModal: false }"
  x-show="showModal"
  x-transition
  class="fixed inset-0 flex items-center justify-center bg-black bg-opacity-50 z-50"
>
  <!-- Modal -->
  <div
    @click.away="showModal = false"
    class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 overflow-hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="loginModalTitle"
  >
    <!-- Header (oculto inicialmente, quita `hidden` para mostrar) -->
    <div class="hidden bg-gray-100 px-6 py-4 border-b">
      <div id="loginModalTitle" class="text-lg font-semibold flex items-center space-x-2">
        <i class="fa fa-user text-blue-500"></i>
        <span>Login</span>
      </div>
      <button
        @click="showModal = false"
        class="absolute top-4 right-4 text-gray-500 hover:text-gray-700 focus:outline-none"
        aria-label="Close"
      >
        &times;
      </button>
    </div>

    <!-- Body -->
    <div class="px-6 py-4">
      <p class="text-gray-700">
        Modal body text goes here.
      </p>
    </div>

    <!-- Footer -->
    <div class="px-6 py-3 bg-gray-50 text-right">
      <button
        @click="showModal = false"
        class="px-4 py-2 bg-gray-300 text-gray-800 rounded hover:bg-gray-400 focus:outline-none"
      >
        Close
      </button>
    </div>
  </div>
</div>
