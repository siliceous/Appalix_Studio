</svg>
                </span>
                <span>Colors</span>
              </button>
              <button type="button" class="svg-editor-tab flex w-full flex-col items-center justify-center gap-1 rounded-lg px-2 py-1.5 text-center hover:text-slate-700 sm:px-3 sm:py-2" data-tab="aspect">
                <span class="svg-editor-tab-icon inline-flex h-5 w-5 items-center justify-center">
