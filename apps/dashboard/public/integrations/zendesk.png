<script data-ii-show-svg-editor-init="1" type="5a26d9c151509a424dfc2f05-text/javascript">
(() => {
  const modal = document.getElementById('svg-editor-modal');
  const openBtn = document.getElementById('svg-editor-open');
  if (!modal || !openBtn) return;

  const canvas = document.getElementById('svg-editor-canvas');
  const stage = document.getElementById('svg-editor-stage');
  const loading = document.getElementById('svg-editor-loading');
  const svgUrl = modal.dataset.svgUrl;
  const presetsUrl = modal.dataset.presetsUrl;
  const paletteUrl = modal.dataset.paletteUrl;
  const useLocalPresets = !presetsUrl;
  const useLocalPalette = !paletteUrl;
  const localPresetsKey = 'svg_editor_local_presets_v1';
  const localPaletteKey = 'svg_editor_local_palette_v1';
  const errorText = modal.dataset.errorText || 'Unable to load SVG';
  const primaryColor = (modal.dataset.primaryColor || '#00c3ff').toUpperCase();
  modal.style.setProperty('--svg-editor-primary', primaryColor);
  const labels = {
    loading: "Loading SVG\u2026",
    copy: "Copy SVG",
    copied: "Copied!",
    copyFailed: "Copy failed",
    auto: "Auto",
    presetsLoading: "Loading presets\u2026",
    presetsEmpty: "No presets yet.",
    presetsSaved: "Preset saved.",
    presetsDeleted: "Preset deleted.",
    presetsError: "Could not save preset.",
    presetsRequired: "Enter a preset name.",
    customPaletteSaved: "Color saved.",
    customPaletteRemoved: "Color removed.",
    customPaletteError: "Could not update palette.",
    premiumTitlePalette: "Create palettes with Premium",
    premiumTitlePresets: "Create presets with Premium",
    premiumTitleDownloadSvg: "Download edited SVG with Premium",
    premiumTitleCopySvg: "Copy edited SVG with Premium"  };
  const csrfToken = document.querySelector('meta[name=\"csrf-token\"]')?.getAttribute('content');

  const sizeInput = document.getElementById('svg-editor-size');
  const paddingInput = document.getElementById('svg-editor-padding');
  const strokeInput = document.getElementById('svg-editor-stroke');
  const colorInput = document.getElementById('svg-editor-color');
  const colorText = document.getElementById('svg-editor-color-text');
  const currentColorInput = document.getElementById('svg-editor-current-color');
  const bgInput = document.getElementById('svg-editor-bg');
  const bgText = document.getElementById('svg-editor-bg-text');
  const sizeValue = document.getElementById('svg-editor-size-value');
  const paddingValue = document.getElementById('svg-editor-padding-value');
  const strokeValue = document.getElementById('svg-editor-stroke-value');
  const singleColorSection = document.getElementById('svg-editor-single-color');

  const flipXBtn = document.getElementById('svg-editor-flip-x');
  const flipYBtn = document.getElementById('svg-editor-flip-y');
  const rotateLeftBtn = document.getElementById('svg-editor-rotate-left');
  const rotateRightBtn = document.getElementById('svg-editor-rotate-right');
  const undoBtn = document.getElementById('svg-editor-undo');
  const redoBtn = document.getElementById('svg-editor-redo');
  const resetBtn = document.getElementById('svg-editor-reset');
  const copyBtn = document.getElementById('svg-editor-copy');
  const copyLabel = copyBtn ? copyBtn.querySelector('[data-copy-label]') : null;
  const downloadBtn = document.getElementById('svg-editor-download');
  const exportPremiumIcons = modal.querySelectorAll('[data-export-premium-icon]');
  const exportPngBtn = document.getElementById('svg-editor-export-png');
  const shapeButtons = modal.querySelectorAll('.svg-editor-shape');
  const bgOptions = document.getElementById('svg-editor-bg-options');
  const bgPaddingInput = document.getElementById('svg-editor-bg-padding');
  const bgPaddingValue = document.getElementById('svg-editor-bg-padding-value');
  const bgRadiusGroup = document.getElementById('svg-editor-bg-radius-group');
  const bgRadiusInput = document.getElementById('svg-editor-bg-radius');
  const bgRadiusValue = document.getElementById('svg-editor-bg-radius-value');
  const regenerateBlobBtn = document.getElementById('svg-editor-regenerate-blob');
  const traceWidthInput = document.getElementById('svg-editor-trace-width');
  const traceWidthValue = document.getElementById('svg-editor-trace-width-value');
  const traceColorInput = document.getElementById('svg-editor-trace-color');
  const traceColorText = document.getElementById('svg-editor-trace-color-text');
  const paletteSection = document.getElementById('svg-editor-palette');
  const paletteList = document.getElementById('svg-editor-palette-list');
  const paletteEmpty = document.getElementById('svg-editor-palette-empty');
  const paletteRefreshBtn = document.getElementById('svg-editor-palette-refresh');
  const palettePickBtn = document.getElementById('svg-editor-palette-pick');
  const pickedRow = document.getElementById('svg-editor-picked');
  const pickedColorInput = document.getElementById('svg-editor-picked-color');
  const pickedTextInput = document.getElementById('svg-editor-picked-text');
  const customPaletteSection = document.getElementById('svg-editor-custom-palette');
  const customPaletteList = document.getElementById('svg-editor-custom-list');
  const customPaletteEmpty = document.getElementById('svg-editor-custom-empty');
  const customPaletteStatus = document.getElementById('svg-editor-custom-status');
  const customPaletteAddBtn = document.getElementById('svg-editor-custom-add');
  const premiumModal = document.getElementById('svg-editor-premium-modal');
  const premiumCloseButtons = premiumModal ? premiumModal.querySelectorAll('[data-premium-close]') : [];
  const premiumTitle = document.getElementById('svg-editor-premium-title');
  const isPremiumUser = true; // v1 sin gating
  const previewPanel = document.getElementById('svg-editor-preview-panel');
  const scrollContainer = modal.querySelector('.svg-editor-scroll');

  const presetsSelect = document.getElementById('svg-editor-presets');
  const presetsApplyBtn = document.getElementById('svg-editor-apply-preset');
  const presetsDeleteBtn = document.getElementById('svg-editor-delete-preset');
  const presetsSaveBtn = document.getElementById('svg-editor-save-preset');
  const presetsNameInput = document.getElementById('svg-editor-preset-name');
  const presetsStatus = document.getElementById('svg-editor-preset-status');
  const presetsRefreshBtn = document.getElementById('svg-editor-refresh-presets');
  const tabButtons = modal.querySelectorAll('.svg-editor-tab');
  const tabPanels = modal.querySelectorAll('.svg-editor-tab-panel');

  let svgEl = null;
  let originalSvg = '';
  let presets = [];
  let presetsLoaded = false;
  let customPaletteLoaded = false;
  let palettePickrs = [];
  const state = {
    size: parseInt(sizeInput.value, 10) || 200,
    padding: parseInt(paddingInput.value, 10) || 0,
    stroke: parseInt(strokeInput.value, 10) || 0,
    color: colorInput.value || '#000000',
    bg: bgInput.value || '#ffffff',
    useCurrentColor: currentColorInput?.checked || false,
    bgShape: 'none',
    bgPadding: parseInt(bgPaddingInput?.value, 10) || 0,
    bgRadius: parseInt(bgRadiusInput?.value, 10) || 0,
    traceWidth: parseInt(traceWidthInput?.value, 10) || 0,
    traceColor: (traceColorInput?.value || '#0F172A').toUpperCase(),
    applyGlobalColor: true,
    palette: [],
    customPalette: [],
    baseViewBox: null,
    viewBox: null,
    blobSeed: 0,
    pickMode: false,
    pickedColor: null,
    flipX: false,
    flipY: false,
    rotate: 0,
    hasEdits: false
  };
  let history = [];
  let historyIndex = -1;
  let historyTimer = null;
  let historyEnabled = false;
  let restoring = false;

  const readLocalJson = (key, fallback) => {
    try {
      const raw = localStorage.getItem(key);
      if (!raw) return fallback;
      const parsed = JSON.parse(raw);
      return parsed ?? fallback;
    } catch (e) {
      return fallback;
    }
  };

  const writeLocalJson = (key, value) => {
    try {
      localStorage.setItem(key, JSON.stringify(value));
    } catch (e) {
      // ignore storage quota/private mode errors
    }
  };

  const updateExportButtons = () => {
    const showPremium = state.hasEdits;
    exportPremiumIcons.forEach((icon) => {
      icon.classList.toggle('hidden', !showPremium);
    });
  };

  const markEdited = () => {
    if (restoring) return;
    state.hasEdits = true;
    updateExportButtons();
  };

  const clearEdits = () => {
    state.hasEdits = false;
    updateExportButtons();
  };

  const closeModal = () => {
    modal.classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    if (premiumModal) premiumModal.classList.add('hidden');
  };

  let previewBaseHeight = null;
  let previewOffsetTop = null;

  const openModal = () => {
    modal.classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    if (!svgEl) loadSvg();
    if (!presetsLoaded) loadPresets();
    if (!customPaletteLoaded) loadCustomPalette();
    requestAnimationFrame(() => {
      updatePreviewMetrics();
      updatePreviewSticky();
    });
  };

  const updatePreviewMetrics = () => {
    if (!previewPanel || !scrollContainer) return;
    const containerRect = scrollContainer.getBoundingClientRect();
    const previewRect = previewPanel.getBoundingClientRect();
    previewBaseHeight = previewPanel.offsetHeight;
    previewOffsetTop = previewRect.top - containerRect.top + scrollContainer.scrollTop;
  };

  const updatePreviewSticky = () => {
    if (!previewPanel || !scrollContainer) return;
    const isMobile = window.innerWidth < 1024;
    if (!isMobile) {
      previewPanel.classList.remove('svg-editor-preview--stuck');
      previewBaseHeight = null;
      previewOffsetTop = null;
      modal.style.removeProperty('--svg-editor-tabs-top');
      return;
    }
    if (!previewBaseHeight || previewOffsetTop === null) {
      updatePreviewMetrics();
    }
    const threshold = Math.max(0, (previewOffsetTop || 0) - 8);
    const isCurrentlyStuck = previewPanel.classList.contains('svg-editor-preview--stuck');
    const shouldStick = scrollContainer.scrollTop >= threshold;
    const shouldUnstick = scrollContainer.scrollTop <= threshold - 20;
    const stuck = isCurrentlyStuck ? !shouldUnstick : shouldStick;
    previewPanel.classList.toggle('svg-editor-preview--stuck', stuck);
    if (stuck && previewBaseHeight) {
      modal.style.setProperty('--svg-editor-tabs-top', `${previewBaseHeight + 8}px`);
    } else {
      modal.style.setProperty('--svg-editor-tabs-top', '0px');
      updatePreviewMetrics();
    }
  };

  modal.querySelectorAll('[data-close]').forEach(btn => btn.addEventListener('click', closeModal));
  openBtn.addEventListener('click', openModal);

  const urlParams = new URLSearchParams(window.location.search);
  const embedEditorOnly = urlParams.get('embed_svg_editor') === '1';
  const shouldAutoOpenEditor = urlParams.get('open_svg_editor') === '1';

  if (embedEditorOnly) {
    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    const modalShell = modal.querySelector('.relative.mx-auto.my-6');
    if (modalShell) {
      modalShell.classList.remove('my-6', 'h-[90vh]', 'w-[95%]', 'max-w-5xl', 'rounded-2xl', 'shadow-2xl');
      modalShell.classList.add('my-0', 'h-screen', 'w-screen', 'max-w-none', 'rounded-none', 'shadow-none');
    }

    modal.querySelectorAll('[data-close]').forEach((el) => {
      el.classList.add('hidden');
    });

    Array.from(document.body.children).forEach((node) => {
      if (node !== modal) {
        node.style.display = 'none';
      }
    });
  }

  if (shouldAutoOpenEditor) {
    urlParams.delete('open_svg_editor');
    urlParams.delete('embed_svg_editor');
    const nextQuery = urlParams.toString();
    const nextUrl = `${window.location.pathname}${nextQuery ? `?${nextQuery}` : ''}${window.location.hash || ''}`;
    window.history.replaceState({}, '', nextUrl);
  }

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  if (premiumModal) {
    premiumModal.addEventListener('click', (e) => {
      if (e.target === premiumModal) premiumModal.classList.add('hidden');
    });
  }
  premiumCloseButtons.forEach((btn) => btn.addEventListener('click', () => {
    if (premiumModal) premiumModal.classList.add('hidden');
  }));
  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('hidden') && e.key === 'Escape') closeModal();
  });

  if (scrollContainer) {
    scrollContainer.addEventListener('scroll', () => requestAnimationFrame(updatePreviewSticky));
  }
  window.addEventListener('resize', () => requestAnimationFrame(updatePreviewSticky));

  const requirePremium = () => false; // gating desactivado en v1

  const parseSvg = (text) => {
    const parser = new DOMParser();
    const doc = parser.parseFromString(text, 'image/svg+xml');
    return doc.querySelector('svg');
  };

  const normalizeViewBox = () => {
    if (!svgEl) return { x: 0, y: 0, width: 512, height: 512 };
    let viewBox = svgEl.getAttribute('viewBox');
    if (!viewBox) {
      const widthAttr = parseFloat(svgEl.getAttribute('width') || '');
      const heightAttr = parseFloat(svgEl.getAttribute('height') || '');
      const width = Number.isFinite(widthAttr) && widthAttr > 0 ? widthAttr : 512;
      const height = Number.isFinite(heightAttr) && heightAttr > 0 ? heightAttr : 512;
      svgEl.setAttribute('viewBox', `0 0 ${width} ${height}`);
      viewBox = svgEl.getAttribute('viewBox');
    }
    const parts = (viewBox || '').split(/\s+|,/).map(Number).filter((n) => Number.isFinite(n));
    if (parts.length === 4) {
      return { x: parts[0], y: parts[1], width: parts[2], height: parts[3] };
    }
    return { x: 0, y: 0, width: 512, height: 512 };
  };

  const getViewBox = () => state.viewBox || normalizeViewBox();
  const serializeSvg = () => {
    if (!svgEl) return '';
    return new XMLSerializer().serializeToString(svgEl);
  };

  const cloneStateForHistory = () => ({
    size: state.size,
    padding: state.padding,
    stroke: state.stroke,
    color: state.color,
    bg: state.bg,
    bgShape: state.bgShape,
    bgPadding: state.bgPadding,
    bgRadius: state.bgRadius,
    traceWidth: state.traceWidth,
    traceColor: state.traceColor,
    applyGlobalColor: state.applyGlobalColor,
    useCurrentColor: state.useCurrentColor,
    flipX: state.flipX,
    flipY: state.flipY,
    rotate: state.rotate,
    blobSeed: state.blobSeed,
    baseViewBox: state.baseViewBox ? { ...state.baseViewBox } : null,
    viewBox: state.viewBox ? { ...state.viewBox } : null
  });

  const updateHistoryButtons = () => {
    if (undoBtn) {
      const disabled = historyIndex <= 0;
      undoBtn.disabled = disabled;
      undoBtn.classList.toggle('opacity-50', disabled);
      undoBtn.classList.toggle('cursor-not-allowed', disabled);
    }
    if (redoBtn) {
      const disabled = historyIndex >= history.length - 1;
      redoBtn.disabled = disabled;
      redoBtn.classList.toggle('opacity-50', disabled);
      redoBtn.classList.toggle('cursor-not-allowed', disabled);
    }
  };

  const pushHistory = (force = false) => {
    if (!historyEnabled || restoring || !svgEl) return;
    if (historyTimer) {
      clearTimeout(historyTimer);
      historyTimer = null;
    }
    const snapshot = {
      svg: serializeSvg(),
      state: cloneStateForHistory()
    };
    const last = history[historyIndex];
    if (!force && last && last.svg === snapshot.svg && JSON.stringify(last.state) === JSON.stringify(snapshot.state)) {
      return;
    }
    history = history.slice(0, historyIndex + 1);
    history.push(snapshot);
    historyIndex = history.length - 1;
    updateHistoryButtons();
  };

  const scheduleHistory = () => {
    if (!historyEnabled || restoring) return;
    if (historyTimer) clearTimeout(historyTimer);
    historyTimer = setTimeout(() => pushHistory(), 250);
  };

  const restoreSnapshot = (snapshot) => {
    if (!snapshot || !snapshot.svg) return;
    if (historyTimer) {
      clearTimeout(historyTimer);
      historyTimer = null;
    }
    const parsed = parseSvg(snapshot.svg);
    if (!parsed) return;
    restoring = true;
    svgEl = parsed;
    svgEl.removeAttribute('width');
    svgEl.removeAttribute('height');
    svgEl.setAttribute('preserveAspectRatio', 'xMidYMid meet');
    if (stage) {
      stage.innerHTML = '';
      stage.appendChild(svgEl);
    }

    Object.assign(state, snapshot.state || {});
    if (!state.baseViewBox) {
      state.baseViewBox = normalizeViewBox();
    }
    if (!state.viewBox && state.baseViewBox) {
      state.viewBox = { ...state.baseViewBox };
    }

    sizeInput.value = state.size;
    paddingInput.value = state.padding;
    strokeInput.value = state.stroke;
    syncColorInputs(state.color, colorText, colorInput);
    syncColorInputs(state.bg, bgText, bgInput);
    syncColorInputs(state.traceColor, traceColorText, traceColorInput);
    if (currentColorInput) currentColorInput.checked = state.useCurrentColor;
    if (bgPaddingInput) bgPaddingInput.value = state.bgPadding;
    if (bgRadiusInput) bgRadiusInput.value = state.bgRadius;
    if (traceWidthInput) traceWidthInput.value = state.traceWidth;
    updateShapeButtons();
    updateBgOptionsVisibility();
    state.palette = collectPalette();
    renderPalette();
    applyAll();
    restoring = false;
    state.hasEdits = historyIndex > 0;
    updateExportButtons();
    updateHistoryButtons();
  };

  const updateShapeButtons = () => {
    if (!shapeButtons.length) return;
    shapeButtons.forEach((btn) => {
      const isActive = btn.dataset.shape === state.bgShape;
      btn.classList.toggle('ring-2', isActive);
      btn.classList.toggle('ring-primary', isActive);
      btn.classList.toggle('border-primary/40', isActive);
    });
  };

  const updateBgOptionsVisibility = () => {
    if (!bgOptions) return;
    const hasShape = state.bgShape !== 'none';
    bgOptions.classList.toggle('hidden', !hasShape);
    if (regenerateBlobBtn) {
      regenerateBlobBtn.classList.toggle('hidden', state.bgShape !== 'blob');
    }
    if (bgRadiusGroup) {
      const showRadius = state.bgShape === 'square' || state.bgShape === 'diamond';
      bgRadiusGroup.classList.toggle('hidden', !showRadius);
    }
  };

  const buildPolygonPath = (points, radius) => {
    if (!radius || radius <= 0) {
      return `M ${points.map(p => `${p.x} ${p.y}`).join(' L ')} Z`;
    }
    let d = '';
    const len = points.length;
    for (let i = 0; i < len; i++) {
      const prev = points[(i - 1 + len) % len];
      const curr = points[i];
      const next = points[(i + 1) % len];
      const v0 = { x: prev.x - curr.x, y: prev.y - curr.y };
      const v1 = { x: next.x - curr.x, y: next.y - curr.y };
      const len0 = Math.hypot(v0.x, v0.y);
      const len1 = Math.hypot(v1.x, v1.y);
      const maxR = Math.min(len0, len1) * 0.45;
      const r = Math.min(radius, maxR);
      const u0 = { x: v0.x / len0, y: v0.y / len0 };
      const u1 = { x: v1.x / len1, y: v1.y / len1 };
      const pA = { x: curr.x + u0.x * r, y: curr.y + u0.y * r };
      const pB = { x: curr.x + u1.x * r, y: curr.y + u1.y * r };
      if (i === 0) {
        d += `M ${pA.x} ${pA.y}`;
      } else {
        d += ` L ${pA.x} ${pA.y}`;
      }
      d += ` Q ${curr.x} ${curr.y} ${pB.x} ${pB.y}`;
    }
    return d + ' Z';
  };

  const mulberry32 = (seed) => () => {
    let t = seed += 0x6D2B79F5;
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };

  const catmullRomToBezier = (points, tension = 0.9) => {
    const len = points.length;
    let d = `M ${points[0].x} ${points[0].y}`;
    for (let i = 0; i < len; i++) {
      const p0 = points[(i - 1 + len) % len];
      const p1 = points[i];
      const p2 = points[(i + 1) % len];
      const p3 = points[(i + 2) % len];
      const cp1 = {
        x: p1.x + (p2.x - p0.x) / 6 * tension,
        y: p1.y + (p2.y - p0.y) / 6 * tension
      };
      const cp2 = {
        x: p2.x - (p3.x - p1.x) / 6 * tension,
        y: p2.y - (p3.y - p1.y) / 6 * tension
      };
      d += ` C ${cp1.x} ${cp1.y} ${cp2.x} ${cp2.y} ${p2.x} ${p2.y}`;
    }
    return d + ' Z';
  };

  const generateBlobPath = ({ x, y, width, height, inset, seed }) => {
    const cx = x + width / 2;
    const cy = y + height / 2;
    const baseRadius = Math.max(8, Math.min(width, height) / 2 - inset);
    const points = [];
    const rng = mulberry32(seed || Math.floor(Math.random() * 1e9));
    const count = 12;
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count;
      const variance = 0.92 + rng() * 0.16;
      const r = baseRadius * variance;
      points.push({
        x: cx + Math.cos(angle) * r,
        y: cy + Math.sin(angle) * r
      });
    }
    return catmullRomToBezier(points);
  };

  const applyBackgroundShape = () => {
    if (!svgEl) return;
    const shapeId = 'svg-editor-bg-shape';
    const { x, y, width, height } = getViewBox();
    const insetRaw = (state.bgPadding / 100) * Math.min(width, height);
    const inset = Math.max(0, Math.min(insetRaw, Math.min(width, height) * 0.45));
    const radiusRaw = (state.bgRadius / 100) * Math.min(width, height);
    const radius = Math.max(0, radiusRaw);

    let shapeEl = svgEl.querySelector(`#${shapeId}`);
    if (state.bgShape === 'none') {
      if (shapeEl) shapeEl.remove();
      updateShapeButtons();
      updateBgOptionsVisibility();
      return;
    }

    const ns = 'http://www.w3.org/2000/svg';
    const isCircle = state.bgShape === 'circle';
    const isSquare = state.bgShape === 'square';
    const isDiamond = state.bgShape === 'diamond';
    const isBlob = state.bgShape === 'blob';

    let desiredTag = 'rect';
    if (isCircle) desiredTag = 'circle';
    if (isDiamond) desiredTag = 'path';
    if (isBlob) desiredTag = 'path';

    if (!shapeEl || shapeEl.tagName.toLowerCase() !== desiredTag) {
      if (shapeEl) shapeEl.remove();
      shapeEl = document.createElementNS(ns, desiredTag);
      shapeEl.setAttribute('id', shapeId);
      shapeEl.setAttribute('data-editor', 'bg-shape');
      svgEl.insertBefore(shapeEl, svgEl.firstChild);
    }

    if (isCircle) {
      shapeEl.setAttribute('cx', x + width / 2);
      shapeEl.setAttribute('cy', y + height / 2);
      shapeEl.setAttribute('r', Math.min(width, height) / 2 - inset);
    } else if (isDiamond) {
      const cx = x + width / 2;
      const cy = y + height / 2;
      const left = x + inset;
      const right = x + width - inset;
      const top = y + inset;
      const bottom = y + height - inset;
      const points = [
        { x: cx, y: top },
        { x: right, y: cy },
        { x: cx, y: bottom },
        { x: left, y: cy }
      ];
      const path = buildPolygonPath(points, radius);
      shapeEl.setAttribute('d', path);
    } else if (isBlob) {
      if (!state.blobSeed) {
        state.blobSeed = Math.floor(Math.random() * 1e9);
      }
      const path = generateBlobPath({ x, y, width, height, inset, seed: state.blobSeed });
      shapeEl.setAttribute('d', path);
    } else if (isSquare) {
      shapeEl.setAttribute('x', x + inset);
      shapeEl.setAttribute('y', y + inset);
      shapeEl.setAttribute('width', width - inset * 2);
      shapeEl.setAttribute('height', height - inset * 2);
      if (radius > 0) {
        shapeEl.setAttribute('rx', radius);
        shapeEl.setAttribute('ry', radius);
      } else {
        shapeEl.removeAttribute('rx');
        shapeEl.removeAttribute('ry');
      }
    }

    shapeEl.setAttribute('fill', state.bg);
    shapeEl.setAttribute('stroke', 'none');
    shapeEl.removeAttribute('stroke-width');
    shapeEl.removeAttribute('vector-effect');
    shapeEl.style.pointerEvents = 'none';
    updateShapeButtons();
    updateBgOptionsVisibility();
  };

  const getStyleValue = (el, prop) => {
    const style = el.getAttribute('style');
    if (!style) return null;
    const entries = style.split(';').map((part) => part.trim()).filter(Boolean);
    for (const entry of entries) {
      const [key, val] = entry.split(':').map((v) => v.trim());
      if (key === prop) return val || null;
    }
    return null;
  };

  const setStyleValue = (el, prop, value) => {
    const style = el.getAttribute('style') || '';
    const entries = style.split(';').map((part) => part.trim()).filter(Boolean);
    const next = [];
    let replaced = false;
    entries.forEach((entry) => {
      const [key] = entry.split(':').map((v) => v.trim());
      if (key === prop) {
        replaced = true;
        next.push(`${prop}:${value}`);
      } else if (key) {
        next.push(entry);
      }
    });
    if (!replaced) next.push(`${prop}:${value}`);
    el.setAttribute('style', next.join(';'));
  };

  const removeStyleValue = (el, prop) => {
    const style = el.getAttribute('style');
    if (!style) return;
    const entries = style.split(';').map((part) => part.trim()).filter(Boolean);
    const next = entries.filter((entry) => {
      const [key] = entry.split(':').map((v) => v.trim());
      return key && key !== prop;
    });
    if (next.length) {
      el.setAttribute('style', next.join(';'));
    } else {
      el.removeAttribute('style');
    }
  };

  const normalizePaint = (value) => {
    if (value === null || value === undefined) return null;
    const normalized = String(value).trim();
    if (!normalized) return null;
    const lower = normalized.toLowerCase();
    if (lower === 'none' || lower === 'transparent') return 'none';
    if (lower.startsWith('rgba') && /,\s*0\)\s*$/.test(lower)) return 'none';
    return normalized;
  };

  const normalizeColor = (value) => {
    if (value === null || value === undefined) return null;
    const raw = String(value).trim();
    if (!raw) return null;
    const lower = raw.toLowerCase();
    if (lower === 'none' || lower === 'transparent' || lower === 'currentcolor') return null;
    if (lower.startsWith('url(')) return null;

    const probe = document.createElement('span');
    probe.style.color = '';
    probe.style.color = raw;
    if (!probe.style.color) return null;
    let normalized = probe.style.color;

    if (normalized.startsWith('rgba')) {
      const parts = normalized.replace(/rgba?\(|\)/g, '').split(',').map((v) => v.trim());
      const alpha = parts[3] !== undefined ? parseFloat(parts[3]) : 1;
      if (!Number.isFinite(alpha) || alpha <= 0) return null;
    }

    if (normalized.startsWith('#')) {
      let hex = normalized.toUpperCase();
      if (hex.length === 4) {
        hex = `#${hex[1]}${hex[1]}${hex[2]}${hex[2]}${hex[3]}${hex[3]}`;
      }
      if (hex.length === 5) {
        const alpha = parseInt(hex[4] + hex[4], 16) / 255;
        if (alpha <= 0) return null;
        hex = `#${hex[1]}${hex[1]}${hex[2]}${hex[2]}${hex[3]}${hex[3]}`;
      }
      if (hex.length === 9) {
        const alpha = parseInt(hex.slice(7, 9), 16) / 255;
        if (alpha <= 0) return null;
        hex = hex.slice(0, 7);
      }
      return hex;
    }

    const rgbMatch = normalized.match(/^rgba?\(([^)]+)\)/i);
    if (rgbMatch) {
      const parts = rgbMatch[1].split(',').map((v) => v.trim());
      const r = Math.max(0, Math.min(255, parseFloat(parts[0])));
      const g = Math.max(0, Math.min(255, parseFloat(parts[1])));
      const b = Math.max(0, Math.min(255, parseFloat(parts[2])));
      const alpha = parts[3] !== undefined ? parseFloat(parts[3]) : 1;
      if (!Number.isFinite(alpha) || alpha <= 0) return null;
      const toHex = (n) => Math.round(n).toString(16).padStart(2, '0').toUpperCase();
      return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
    }

    return null;
  };

  const getPaintValue = (el, prop) => {
    const attr = el.getAttribute(prop);
    const styleVal = getStyleValue(el, prop);
    return attr ?? styleVal;
  };

  const resolvePaletteColor = (el, prop, computed) => {
    const raw = getPaintValue(el, prop);
    const explicit = normalizeColor(raw);
    if (explicit) return { color: explicit, source: 'explicit' };
    const computedVal = computed ? (prop === 'fill' ? computed.fill : computed.stroke) : null;
    const computedNorm = normalizeColor(computedVal);
    if (!computedNorm) return null;
    return { color: computedNorm, source: 'computed' };
  };

  const collectPalette = () => {
    if (!svgEl) return [];
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';
    const map = new Map();
    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        return;
      }
      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        return;
      }
      if (el.getAttribute('data-editor-trace') === '1') {
        return;
      }
      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      ['fill', 'stroke'].forEach((prop) => {
        const resolved = resolvePaletteColor(el, prop, computed);
        if (!resolved) return;
        const entry = map.get(resolved.color) || { count: 0, explicit: 0 };
        entry.count += 1;
        if (resolved.source === 'explicit') entry.explicit += 1;
        map.set(resolved.color, entry);
      });
    });
    if (map.size > 1) {
      const black = map.get('#000000');
      if (black && black.explicit === 0 && black.count <= 1) {
        map.delete('#000000');
      }
    }
    return Array.from(map.keys());
  };

  const replaceColor = (oldColor, newColor) => {
    if (!svgEl) return;
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';
    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        return;
      }
      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        return;
      }
      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      ['fill', 'stroke'].forEach((prop) => {
        const attr = el.getAttribute(prop);
        const styleVal = getStyleValue(el, prop);
        const resolved = resolvePaletteColor(el, prop, computed);
        if (!resolved || resolved.color !== oldColor) return;
        if (attr) {
          el.setAttribute(prop, newColor);
        } else if (styleVal) {
          setStyleValue(el, prop, newColor);
        } else {
          setStyleValue(el, prop, newColor);
        }
      });
    });
  };

  const updateColorModeUI = () => {
    const multi = state.palette.length > 1;
    if (singleColorSection) singleColorSection.classList.toggle('hidden', multi);
    if (paletteSection) paletteSection.classList.toggle('hidden', !multi);
    if (!multi) {
      state.pickMode = false;
      if (palettePickBtn) palettePickBtn.classList.remove('text-primary');
      canvas.classList.remove('cursor-crosshair');
      state.pickedColor = null;
      highlightPaletteColor(null);
    }
  };

  const setActiveTab = (name) => {
    if (!tabButtons.length || !tabPanels.length) return;
    tabButtons.forEach((btn) => {
      const active = btn.dataset.tab === name;
      btn.classList.toggle('bg-slate-100', active);
      btn.classList.toggle('text-slate-900', active);
      btn.classList.toggle('text-slate-500', !active);
    });
    tabPanels.forEach((panel) => {
      panel.classList.toggle('hidden', panel.dataset.tabPanel !== name);
    });
  };

  const renderPalette = () => {
    if (!paletteList) return;
    palettePickrs.forEach((pickr) => {
      if (!pickr) return;
      if (typeof pickr.destroyAndRemove === 'function') {
        pickr.destroyAndRemove();
      } else if (typeof pickr.destroy === 'function') {
        pickr.destroy();
      }
    });
    palettePickrs = [];
    paletteList.innerHTML = '';
    if (!state.palette.length) {
      paletteEmpty?.classList.remove('hidden');
      updateColorModeUI();
      return;
    }
    paletteEmpty?.classList.add('hidden');
    updateColorModeUI();
    state.palette.forEach((color) => {
      const row = document.createElement('div');
      row.className = 'rounded-md w-fit flex items-center justify-center leading-none';
      row.setAttribute('data-palette-color', color.toUpperCase());
      row.innerHTML = `
        <button type="button" class="svg-editor-pickr block h-12 w-12 cursor-pointer rounded border" data-pickr-inline style="background:${color}" aria-label="${color}"></button>
        <input type="hidden" value="${color}" data-color-input>
      `;
      const colorInput = row.querySelector('[data-color-input]');
      const pickrBtn = row.querySelector('[data-pickr-inline]');
      colorInput.dataset.old = color;
      if (pickrBtn && window.createSvgEditorPickr) {
        const pickr = window.createSvgEditorPickr(pickrBtn, colorInput);
        if (pickr) palettePickrs.push(pickr);
      }

      const applyReplace = (oldColor, newColor, { rerender = true } = {}) => {
        replaceColor(oldColor, newColor);
        colorInput.dataset.old = newColor;
        colorInput.value = newColor;
        row.setAttribute('data-palette-color', newColor.toUpperCase());
        state.pickedColor = newColor;
        const oldUpper = String(oldColor || '').toUpperCase();
        const newUpper = String(newColor || '').toUpperCase();
        const idx = state.palette.findIndex((entry) => entry.toUpperCase() === oldUpper);
        if (idx !== -1) {
          state.palette.splice(idx, 1, newUpper);
        }
        if (rerender) {
          state.palette = collectPalette();
          renderPalette();
        } else {
          updateColorModeUI();
          highlightPaletteColor(newUpper);
        }
        markEdited();
        scheduleHistory();
      };

      if (pickrBtn) {
        pickrBtn.addEventListener('click', () => {
          const current = (colorInput.dataset.old || colorInput.value || color).toUpperCase();
          setPickedColor(current);
        });
      }

      colorInput.addEventListener('input', () => {
        const newColor = colorInput.value.toUpperCase();
        const oldColor = colorInput.dataset.old || color;
        state.applyGlobalColor = false;
        if (currentColorInput) currentColorInput.checked = false;
        state.useCurrentColor = false;
        applyReplace(oldColor, newColor, { rerender: false });
      });

      row.addEventListener('click', (e) => {
        if (e.target instanceof HTMLButtonElement) return;
        const current = (colorInput.dataset.old || color).toUpperCase();
        setPickedColor(current);
      });

      paletteList.appendChild(row);
    });
    if (state.pickedColor) {
      highlightPaletteColor(state.pickedColor);
    }
  };

  const normalizeHexColor = (value) => {
    const normalized = normalizeColor(value);
    return normalized ? normalized.toUpperCase() : null;
  };

  const setCustomPaletteStatus = (text) => {
    if (!customPaletteStatus) return;
    customPaletteStatus.textContent = text || '';
  };

  const renderCustomPalette = () => {
    if (!customPaletteList) return;
    customPaletteList.innerHTML = '';
    if (!state.customPalette.length) {
      customPaletteEmpty?.classList.remove('hidden');
      return;
    }
    customPaletteEmpty?.classList.add('hidden');
    state.customPalette.forEach((color) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'relative w-fit';
      wrapper.innerHTML = `
        <button type="button" class="h-12 w-12 cursor-pointer rounded border" data-swatch title="${color}" style="background:${color}"></button>
        <button type="button" class="absolute -top-1 -right-1 h-4 w-4 rounded-full border bg-white text-[10px] font-bold text-slate-500 hover:text-slate-700" data-remove>&times;</button>
      `;
      const swatch = wrapper.querySelector('[data-swatch]');
      const removeBtn = wrapper.querySelector('[data-remove]');
      swatch.addEventListener('click', () => {
        applyCustomPaletteColor(color);
      });
      removeBtn.addEventListener('click', (event) => {
        event.stopPropagation();
        removeCustomPaletteColor(color);
      });
      customPaletteList.appendChild(wrapper);
    });
  };

  const refreshPalette = () => {
    state.palette = collectPalette();
    renderPalette();
  };

  const loadCustomPalette = async () => {
    if (useLocalPalette) {
      const colors = readLocalJson(localPaletteKey, []);
      state.customPalette = Array.from(new Set((Array.isArray(colors) ? colors : []).map(normalizeHexColor).filter(Boolean)));
      customPaletteLoaded = true;
      renderCustomPalette();
      return;
    }
    if (!paletteUrl) return;
    try {
      const res = await fetch(paletteUrl, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('palette');
      const data = await res.json();
      const colors = Array.isArray(data?.colors) ? data.colors : [];
      state.customPalette = Array.from(new Set(colors.map(normalizeHexColor).filter(Boolean)));
      customPaletteLoaded = true;
      renderCustomPalette();
    } catch (e) {
      setCustomPaletteStatus(labels.customPaletteError);
    }
  };

  const saveCustomPaletteColor = async (color) => {
    const normalized = normalizeHexColor(color);
    if (!normalized) return;
    if (useLocalPalette) {
      const colors = Array.from(new Set([...(state.customPalette || []), normalized].map(normalizeHexColor).filter(Boolean)));
      state.customPalette = colors;
      customPaletteLoaded = true;
      writeLocalJson(localPaletteKey, colors);
      renderCustomPalette();
      setCustomPaletteStatus(labels.customPaletteSaved);
      return;
    }
    if (!paletteUrl) return;
    try {
      const res = await fetch(paletteUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-TOKEN': csrfToken || '',
        },
        body: JSON.stringify({ color: normalized }),
      });
      if (!res.ok) throw new Error('palette');
      const data = await res.json();
      const colors = Array.isArray(data?.colors) ? data.colors : [];
      state.customPalette = Array.from(new Set(colors.map(normalizeHexColor).filter(Boolean)));
      customPaletteLoaded = true;
      renderCustomPalette();
      setCustomPaletteStatus(labels.customPaletteSaved);
    } catch (e) {
      setCustomPaletteStatus(labels.customPaletteError);
    }
  };

  const removeCustomPaletteColor = async (color) => {
    const normalized = normalizeHexColor(color);
    if (!normalized) return;
    if (useLocalPalette) {
      const colors = (state.customPalette || []).map((entry) => normalizeHexColor(entry)).filter(Boolean);
      state.customPalette = colors.filter((entry) => entry !== normalized);
      writeLocalJson(localPaletteKey, state.customPalette);
      renderCustomPalette();
      setCustomPaletteStatus(labels.customPaletteRemoved);
      return;
    }
    if (!paletteUrl) return;
    const safe = normalized.replace('#', '');
    try {
      const res = await fetch(`${paletteUrl}/${encodeURIComponent(safe)}`, {
        method: 'DELETE',
        headers: {
          'X-CSRF-TOKEN': csrfToken || '',
        },
      });
      if (!res.ok) throw new Error('palette');
      const data = await res.json();
      const colors = Array.isArray(data?.colors) ? data.colors : [];
      state.customPalette = Array.from(new Set(colors.map(normalizeHexColor).filter(Boolean)));
      renderCustomPalette();
      setCustomPaletteStatus(labels.customPaletteRemoved);
    } catch (e) {
      setCustomPaletteStatus(labels.customPaletteError);
    }
  };

  const applyCustomPaletteColor = (color) => {
    const normalized = normalizeHexColor(color);
    if (!normalized) return;

    if (state.palette.length <= 1) {
      state.color = normalized;
      if (colorInput) colorInput.value = normalized;
      state.applyGlobalColor = true;
      state.useCurrentColor = false;
      if (currentColorInput) currentColorInput.checked = false;
      markEdited();
      applyColor();
      scheduleHistory();
      return;
    }

    const target = state.pickedColor || state.palette[0];
    if (!target) return;
    replaceColor(target, normalized);
    state.pickedColor = normalized;
    state.palette = collectPalette();
    renderPalette();
    markEdited();
    scheduleHistory();
  };

  const getCustomPaletteSourceColor = () => {
    if (state.palette.length > 1) {
      return state.pickedColor || state.palette[0];
    }
    return state.color || colorInput?.value || '#000000';
  };

  const highlightPaletteColor = (color) => {
    if (!paletteList) return;
    const target = color ? color.toUpperCase() : null;
    paletteList.querySelectorAll('[data-palette-color]').forEach((row) => {
      const match = target && row.getAttribute('data-palette-color') === target;
      const swatch = row.querySelector('button');
      if (!swatch) return;
      swatch.classList.toggle('ring-2', match);
      swatch.classList.toggle('ring-primary', match);
    });
  };

  const applyHighlightColor = (color) => {
    if (!svgEl) return;
    const target = color ? color.toUpperCase() : null;
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';
    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        el.classList.remove('svg-editor-highlight');
        return;
      }
      if (el.getAttribute('data-editor-trace') === '1') {
        el.classList.remove('svg-editor-highlight');
        return;
      }
      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        el.classList.remove('svg-editor-highlight');
        return;
      }
      if (!target) {
        el.classList.remove('svg-editor-highlight');
        return;
      }
      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      const fillResolved = resolvePaletteColor(el, 'fill', computed);
      const strokeResolved = resolvePaletteColor(el, 'stroke', computed);
      const match = (fillResolved?.color === target) || (strokeResolved?.color === target);
      el.classList.toggle('svg-editor-highlight', match);
    });
  };

  const setPickedColor = (color) => {
    if (!color) return;
    const normalized = color.toUpperCase();
    state.pickedColor = normalized;
    highlightPaletteColor(normalized);
  };

  const handlePick = (event) => {
    if (!svgEl) return;
    const target = event.target;
    if (!(target instanceof Element)) return;
    if (!svgEl.contains(target)) return;
    if (target.getAttribute('data-editor') === 'bg-shape' || target.id === 'svg-editor-bg-shape') return;

    const computed = window.getComputedStyle ? window.getComputedStyle(target) : null;
    const fill = normalizeColor(computed?.fill);
    const stroke = normalizeColor(computed?.stroke);
    const picked = fill || stroke;
    if (!picked) return;

    setPickedColor(picked);
    if (state.pickMode && palettePickBtn) {
      state.pickMode = false;
      palettePickBtn.classList.remove('text-primary');
      canvas.classList.remove('cursor-crosshair');
    }
  };

  let hoverColor = null;

  const clearHoverHighlight = () => {
    hoverColor = null;
    applyHighlightColor(null);
  };

  const handleHover = (event) => {
    if (!svgEl) return;
    const target = event.target;
    if (!(target instanceof Element)) {
      clearHoverHighlight();
      return;
    }
    if (!svgEl.contains(target)) {
      clearHoverHighlight();
      return;
    }
    if (target.getAttribute('data-editor') === 'bg-shape' || target.id === 'svg-editor-bg-shape') {
      clearHoverHighlight();
      return;
    }
    if (target.getAttribute('data-editor-trace') === '1') {
      clearHoverHighlight();
      return;
    }
    if (target.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
      clearHoverHighlight();
      return;
    }

    const computed = window.getComputedStyle ? window.getComputedStyle(target) : null;
    const fillResolved = resolvePaletteColor(target, 'fill', computed);
    const strokeResolved = resolvePaletteColor(target, 'stroke', computed);
    const color = fillResolved?.color || strokeResolved?.color;
    if (!color) {
      clearHoverHighlight();
      return;
    }
    if (hoverColor === color) return;
    hoverColor = color;
    applyHighlightColor(color);
  };

  canvas.addEventListener('click', handlePick);

  const storeOriginalStrokeWidth = (el) => {
    if (el.hasAttribute('data-editor-stroke-width-attr')) return;
    const attr = el.getAttribute('stroke-width');
    const styleVal = getStyleValue(el, 'stroke-width');
    el.setAttribute('data-editor-stroke-width-attr', attr ?? '');
    el.setAttribute('data-editor-stroke-width-style', styleVal ?? '');
  };

  const restoreOriginalStrokeWidth = (el) => {
    if (!el.hasAttribute('data-editor-stroke-width-attr')) return;
    const attr = el.getAttribute('data-editor-stroke-width-attr');
    const styleVal = el.getAttribute('data-editor-stroke-width-style');

    if (attr) {
      el.setAttribute('stroke-width', attr);
    } else {
      el.removeAttribute('stroke-width');
    }

    if (styleVal) {
      setStyleValue(el, 'stroke-width', styleVal);
    } else {
      removeStyleValue(el, 'stroke-width');
    }
  };

  const storeOriginalTrace = (el) => {
    if (el.hasAttribute('data-editor-trace-stored')) return;
    el.setAttribute('data-editor-trace-stored', '1');
    el.setAttribute('data-editor-trace-stroke-attr', el.getAttribute('stroke') ?? '');
    el.setAttribute('data-editor-trace-stroke-style', getStyleValue(el, 'stroke') ?? '');
    el.setAttribute('data-editor-trace-width-attr', el.getAttribute('stroke-width') ?? '');
    el.setAttribute('data-editor-trace-width-style', getStyleValue(el, 'stroke-width') ?? '');
    el.setAttribute('data-editor-trace-paint-order', el.getAttribute('paint-order') ?? '');
  };

  const restoreOriginalTrace = (el) => {
    if (!el.hasAttribute('data-editor-trace-stored')) return;
    const strokeAttr = el.getAttribute('data-editor-trace-stroke-attr');
    const strokeStyle = el.getAttribute('data-editor-trace-stroke-style');
    const widthAttr = el.getAttribute('data-editor-trace-width-attr');
    const widthStyle = el.getAttribute('data-editor-trace-width-style');
    const paintOrder = el.getAttribute('data-editor-trace-paint-order');

    if (strokeAttr) {
      el.setAttribute('stroke', strokeAttr);
    } else {
      el.removeAttribute('stroke');
    }
    if (strokeStyle) {
      setStyleValue(el, 'stroke', strokeStyle);
    } else {
      removeStyleValue(el, 'stroke');
    }

    if (widthAttr) {
      el.setAttribute('stroke-width', widthAttr);
    } else {
      el.removeAttribute('stroke-width');
    }
    if (widthStyle) {
      setStyleValue(el, 'stroke-width', widthStyle);
    } else {
      removeStyleValue(el, 'stroke-width');
    }

    if (paintOrder) {
      el.setAttribute('paint-order', paintOrder);
    } else {
      el.removeAttribute('paint-order');
    }

    el.removeAttribute('vector-effect');
    el.removeAttribute('data-editor-trace');
    el.removeAttribute('data-editor-trace-stored');
    el.removeAttribute('data-editor-trace-stroke-attr');
    el.removeAttribute('data-editor-trace-stroke-style');
    el.removeAttribute('data-editor-trace-width-attr');
    el.removeAttribute('data-editor-trace-width-style');
    el.removeAttribute('data-editor-trace-paint-order');
  };

  const applyTrace = () => {
    if (!svgEl) return;
    const width = state.traceWidth;
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';

    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        return;
      }
      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        return;
      }

      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      const hasTrace = el.getAttribute('data-editor-trace') === '1';

      if (width > 0) {
        if (!hasTrace) storeOriginalTrace(el);
        el.setAttribute('stroke', state.traceColor);
        setStyleValue(el, 'stroke', state.traceColor);
        el.setAttribute('stroke-width', width);
        setStyleValue(el, 'stroke-width', width);
        el.setAttribute('vector-effect', 'non-scaling-stroke');
        el.setAttribute('paint-order', 'stroke fill');
        el.setAttribute('data-editor-trace', '1');
      } else if (hasTrace) {
        restoreOriginalTrace(el);
      }
    });
  };

  const applyStrokeWidth = () => {
    if (!svgEl) return;
    const strokeWidth = state.stroke;
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';

    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        return;
      }
      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        return;
      }

      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      const fillAttr = normalizePaint(el.getAttribute('fill'));
      const strokeAttr = normalizePaint(el.getAttribute('stroke'));
      const fillStyle = normalizePaint(getStyleValue(el, 'fill'));
      const strokeStyle = normalizePaint(getStyleValue(el, 'stroke'));
      const fillComputed = normalizePaint(computed?.fill);
      const strokeComputed = normalizePaint(computed?.stroke);

      const fillValue = (fillAttr ?? fillStyle ?? fillComputed);
      const strokeValue = (strokeAttr ?? strokeStyle ?? strokeComputed);
      const strokeWidthComputed = parseFloat(computed?.strokeWidth || '');
      const hasStroke = (strokeValue && strokeValue !== 'none')
        || (Number.isFinite(strokeWidthComputed) && strokeWidthComputed > 0);

      if (hasStroke || fillValue === 'none') {
        if (strokeWidth > 0) {
          storeOriginalStrokeWidth(el);
          el.setAttribute('stroke-width', strokeWidth);
          setStyleValue(el, 'stroke-width', strokeWidth);
        } else {
          restoreOriginalStrokeWidth(el);
        }
      }
    });
  };

  const applyColor = () => {
    if (!svgEl) return;
    if (!state.applyGlobalColor && !state.useCurrentColor) return;
    const targetColor = state.useCurrentColor ? 'currentColor' : state.color;
    const selector = 'path, circle, rect, ellipse, polygon, polyline, line, g, use';

    if (state.useCurrentColor) {
      svgEl.style.color = state.color;
    } else {
      svgEl.style.color = '';
    }

    svgEl.querySelectorAll(selector).forEach((el) => {
      if (el.getAttribute('data-editor') === 'bg-shape' || el.id === 'svg-editor-bg-shape') {
        return;
      }

      if (el.closest('defs, clipPath, mask, pattern, linearGradient, radialGradient')) {
        return;
      }
      if (el.getAttribute('data-editor-trace') === '1') {
        return;
      }

      const computed = window.getComputedStyle ? window.getComputedStyle(el) : null;
      const fillAttr = normalizePaint(el.getAttribute('fill'));
      const strokeAttr = normalizePaint(el.getAttribute('stroke'));
      const fillStyle = normalizePaint(getStyleValue(el, 'fill'));
      const strokeStyle = normalizePaint(getStyleValue(el, 'stroke'));
      const fillComputed = normalizePaint(computed?.fill);
      const strokeComputed = normalizePaint(computed?.stroke);

      const fillValue = (fillAttr ?? fillStyle ?? fillComputed);
      const strokeValue = (strokeAttr ?? strokeStyle ?? strokeComputed);

      const hasFill = fillValue && fillValue !== 'none';
      const hasStroke = strokeValue && strokeValue !== 'none';

      if (hasFill) {
        el.setAttribute('fill', targetColor);
        setStyleValue(el, 'fill', targetColor);
      } else if (fillValue === 'none') {
        el.setAttribute('fill', 'none');
        setStyleValue(el, 'fill', 'none');
      } else if (hasStroke) {
        el.setAttribute('fill', 'none');
        setStyleValue(el, 'fill', 'none');
      } else {
        el.setAttribute('fill', targetColor);
        setStyleValue(el, 'fill', targetColor);
      }

      if (hasStroke) {
        el.setAttribute('stroke', targetColor);
        setStyleValue(el, 'stroke', targetColor);
      } else if (fillValue === 'none') {
        el.setAttribute('stroke', targetColor);
        setStyleValue(el, 'stroke', targetColor);
      } else {
        if (strokeValue === 'none') {
          el.setAttribute('stroke', 'none');
          setStyleValue(el, 'stroke', 'none');
        }
      }
    });

  };

  const applyTransform = () => {
    if (!svgEl) return;
    const scaleX = state.flipX ? -1 : 1;
    const scaleY = state.flipY ? -1 : 1;
    svgEl.style.transformOrigin = '50% 50%';
    svgEl.style.transform = `scaleX(${scaleX}) scaleY(${scaleY}) rotate(${state.rotate}deg)`;
  };

  const applySizing = () => {
    if (!svgEl) return;
    svgEl.style.width = `${state.size}px`;
    svgEl.style.height = `${state.size}px`;
    canvas.style.padding = '0px';
    if (state.bgShape === 'none') {
      canvas.style.setProperty('--svg-editor-bg', state.bg);
    } else {
      canvas.style.setProperty('--svg-editor-bg', 'transparent');
    }
    sizeValue.textContent = `${state.size}px`;
    paddingValue.textContent = `${state.padding}%`;
    strokeValue.textContent = state.stroke > 0 ? `${state.stroke}` : labels.auto;
    if (bgPaddingValue) {
      bgPaddingValue.textContent = `${state.bgPadding}%`;
    }
    if (bgRadiusValue) {
      bgRadiusValue.textContent = `${state.bgRadius}%`;
    }
    if (traceWidthValue) {
      traceWidthValue.textContent = `${state.traceWidth}`;
    }
  };

  const applyPadding = () => {
    if (!svgEl || !state.baseViewBox) return;
    const base = state.baseViewBox;
    const unit = Math.min(base.width, base.height);
    const pad = (state.padding / 100) * unit;
    const next = {
      x: base.x - pad,
      y: base.y - pad,
      width: base.width + pad * 2,
      height: base.height + pad * 2
    };
    state.viewBox = next;
    svgEl.setAttribute('viewBox', `${next.x} ${next.y} ${next.width} ${next.height}`);
  };

  const applyAll = () => {
    applySizing();
    applyPadding();
    applyBackgroundShape();
    applyTrace();
    applyStrokeWidth();
    applyColor();
    applyTransform();
    scheduleHistory();
  };

  const loadSvg = async () => {
    try {
      historyEnabled = false;
      history = [];
      historyIndex = -1;
      updateHistoryButtons();
      loading.textContent = labels.loading;
      const res = await fetch(svgUrl, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('failed');
      const text = await res.text();
      originalSvg = text;
      const parsed = parseSvg(text);
      if (!parsed) throw new Error('no svg');
      svgEl = parsed;
      const baseViewBox = normalizeViewBox();
      state.baseViewBox = baseViewBox;
      state.viewBox = { ...baseViewBox };
      svgEl.removeAttribute('width');
      svgEl.removeAttribute('height');
      svgEl.setAttribute('preserveAspectRatio', 'xMidYMid meet');
      if (stage) {
        stage.innerHTML = '';
        stage.appendChild(svgEl);
      }
      state.palette = collectPalette();
      if (state.palette.length === 1) {
        state.color = state.palette[0];
        syncColorInputs(state.color, colorText, colorInput);
      }
      state.applyGlobalColor = state.palette.length === 1;
      renderPalette();
      applyAll();
      clearEdits();
      historyEnabled = true;
      pushHistory(true);
    } catch (e) {
      if (stage) {
        stage.innerHTML = `<div class="text-sm text-red-600">${errorText}</div>`;
      }
    }
  };

  const syncColorInputs = (value, textEl, inputEl) => {
    const normalized = value ? value.toUpperCase() : value;
    if (textEl) textEl.value = normalized || '';
    if (inputEl) {
      inputEl.value = normalized || '';
      const pickerEntry = window.svgEditorPickers?.[inputEl.id];
      if (pickerEntry?.pickr && normalized) {
        pickerEntry.pickr.setColor(normalized, true);
        if (pickerEntry.button) pickerEntry.button.style.background = normalized;
      }
    }
  };

  const setPresetStatus = (text) => {
    if (!presetsStatus) return;
    presetsStatus.textContent = text || '';
  };

  const renderPresets = () => {
    if (!presetsSelect) return;
    const selected = presetsSelect.value;
    presetsSelect.innerHTML = '';
    const defaultOpt = document.createElement('option');
    defaultOpt.value = '';
    defaultOpt.textContent = "Select a preset";
    presetsSelect.appendChild(defaultOpt);
    presets.forEach((preset) => {
      const opt = document.createElement('option');
      opt.value = preset.id;
      opt.textContent = preset.name;
      presetsSelect.appendChild(opt);
    });
    if (selected) presetsSelect.value = selected;
    setPresetStatus(presets.length ? '' : labels.presetsEmpty);
  };

  const getPresetPayload = () => ({
    size: state.size,
    padding: state.padding,
    stroke: state.stroke,
    color: state.color,
    bg: state.bg,
    bgShape: state.bgShape,
    bgPadding: state.bgPadding,
    bgRadius: state.bgRadius,
    blobSeed: state.blobSeed,
    traceWidth: state.traceWidth,
    traceColor: state.traceColor,
    flipX: state.flipX,
    flipY: state.flipY,
    rotate: state.rotate,
    useCurrentColor: state.useCurrentColor
  });

  const applyPreset = (preset) => {
    if (!preset || !preset.settings) return;
    const settings = preset.settings;
    const wasRestoring = restoring;
    restoring = true;
    state.size = parseInt(settings.size ?? state.size, 10);
    state.padding = parseInt(settings.padding ?? state.padding, 10);
    state.stroke = parseInt(settings.stroke ?? state.stroke, 10);
    state.color = settings.color ?? state.color;
    state.bg = settings.bg ?? state.bg;
    state.bgShape = settings.bgShape ?? state.bgShape;
    state.bgPadding = parseInt(settings.bgPadding ?? state.bgPadding, 10);
    state.bgRadius = parseInt(settings.bgRadius ?? state.bgRadius, 10);
    state.blobSeed = parseInt(settings.blobSeed ?? state.blobSeed, 10) || state.blobSeed;
    state.traceWidth = parseInt(settings.traceWidth ?? state.traceWidth, 10);
    state.traceColor = settings.traceColor ?? state.traceColor;
    state.flipX = !!settings.flipX;
    state.flipY = !!settings.flipY;
    state.rotate = parseInt(settings.rotate ?? state.rotate, 10);
    state.useCurrentColor = !!settings.useCurrentColor;
    state.applyGlobalColor = !!settings.applyGlobalColor;

    sizeInput.value = state.size;
    paddingInput.value = state.padding;
    strokeInput.value = state.stroke;
    syncColorInputs(state.color, colorText, colorInput);
    syncColorInputs(state.bg, bgText, bgInput);
    syncColorInputs(state.traceColor, traceColorText, traceColorInput);
    if (currentColorInput) currentColorInput.checked = state.useCurrentColor;
    if (bgPaddingInput) bgPaddingInput.value = state.bgPadding;
    if (bgRadiusInput) bgRadiusInput.value = state.bgRadius;
    if (traceWidthInput) traceWidthInput.value = state.traceWidth;
    updateShapeButtons();
    updateBgOptionsVisibility();
    if (!settings.applyGlobalColor && !state.useCurrentColor) {
      state.applyGlobalColor = false;
    }
    applyAll();
    refreshPalette();
    if (state.palette.length === 1) {
      state.color = state.palette[0];
      syncColorInputs(state.color, colorText, colorInput);
      state.applyGlobalColor = true;
      applyColor();
    }
    restoring = wasRestoring;
    scheduleHistory();
    markEdited();
  };

  const loadPresets = async () => {
    if (useLocalPresets) {
      const local = readLocalJson(localPresetsKey, []);
      presets = Array.isArray(local) ? local : [];
      presetsLoaded = true;
      renderPresets();
      if (!presets.length) setPresetStatus(labels.presetsEmpty);
      return;
    }
    if (!presetsUrl) return;
    setPresetStatus(labels.presetsLoading);
    try {
      const res = await fetch(presetsUrl, { credentials: 'same-origin' });
      if (!res.ok) throw new Error('load');
      presets = await res.json();
      presetsLoaded = true;
      renderPresets();
      if (!presets.length) setPresetStatus(labels.presetsEmpty);
    } catch (e) {
      setPresetStatus(labels.presetsError);
    }
  };

  sizeInput.addEventListener('input', () => {
    state.size = parseInt(sizeInput.value, 10) || 200;
    markEdited();
    applyAll();
  });
  paddingInput.addEventListener('input', () => {
    state.padding = parseInt(paddingInput.value, 10) || 0;
    markEdited();
    applyAll();
  });
  strokeInput.addEventListener('input', () => {
    state.stroke = parseInt(strokeInput.value, 10) || 0;
    markEdited();
    applyAll();
  });
  colorInput.addEventListener('input', () => {
    if (restoring) return;
    state.color = colorInput.value;
    syncColorInputs(state.color, colorText, colorInput);
    state.applyGlobalColor = true;
    markEdited();
    applyAll();
    refreshPalette();
  });
  if (colorText) {
    colorText.addEventListener('change', () => {
      const val = colorText.value.trim();
      if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(val)) {
        state.color = val;
        syncColorInputs(state.color, colorText, colorInput);
        state.applyGlobalColor = true;
        markEdited();
        applyAll();
        refreshPalette();
      }
    });
  }
  bgInput.addEventListener('input', () => {
    if (restoring) return;
    state.bg = bgInput.value;
    syncColorInputs(state.bg, bgText, bgInput);
    markEdited();
    applyAll();
  });
  if (bgText) {
    bgText.addEventListener('change', () => {
      const val = bgText.value.trim();
      if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(val)) {
        state.bg = val;
        syncColorInputs(state.bg, bgText, bgInput);
        markEdited();
        applyAll();
      }
    });
  }

  if (currentColorInput) {
    currentColorInput.addEventListener('change', () => {
      state.useCurrentColor = currentColorInput.checked;
      if (state.useCurrentColor) state.applyGlobalColor = true;
      markEdited();
      applyAll();
    });
  }

  flipXBtn.addEventListener('click', () => {
    state.flipX = !state.flipX;
    markEdited();
    applyAll();
  });
  flipYBtn.addEventListener('click', () => {
    state.flipY = !state.flipY;
    markEdited();
    applyAll();
  });
  rotateLeftBtn.addEventListener('click', () => {
    state.rotate -= 90;
    markEdited();
    applyAll();
  });
  rotateRightBtn.addEventListener('click', () => {
    state.rotate += 90;
    markEdited();
    applyAll();
  });

  if (shapeButtons.length) {
    shapeButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        state.bgShape = btn.dataset.shape || 'none';
        if (state.bgShape === 'blob' && !state.blobSeed) {
          state.blobSeed = Math.floor(Math.random() * 1e9);
        }
        if (state.bgShape === 'blob' && state.bgPadding === 0) {
          state.bgPadding = 8;
          if (bgPaddingInput) bgPaddingInput.value = state.bgPadding;
        }
        if (state.bgShape !== 'none') {
          const defaultBg = (bgInput?.defaultValue || '#ffffff').toUpperCase();
          if (state.bg.toUpperCase() === defaultBg) {
            state.bg = primaryColor;
            syncColorInputs(state.bg, bgText, bgInput);
          }
        }
        markEdited();
        applyAll();
      });
    });
    updateShapeButtons();
    updateBgOptionsVisibility();
  }

  if (bgPaddingInput) {
    bgPaddingInput.addEventListener('input', () => {
      state.bgPadding = parseInt(bgPaddingInput.value, 10) || 0;
      markEdited();
      applyAll();
    });
  }

  if (bgRadiusInput) {
    bgRadiusInput.addEventListener('input', () => {
      state.bgRadius = parseInt(bgRadiusInput.value, 10) || 0;
      markEdited();
      applyAll();
    });
  }

  if (traceWidthInput) {
    traceWidthInput.addEventListener('input', () => {
      state.traceWidth = parseInt(traceWidthInput.value, 10) || 0;
      markEdited();
      applyAll();
    });
  }

  if (traceColorInput) {
    traceColorInput.addEventListener('input', () => {
      if (restoring) return;
      state.traceColor = traceColorInput.value.toUpperCase();
      syncColorInputs(state.traceColor, traceColorText, traceColorInput);
      markEdited();
      applyAll();
    });
  }

  if (traceColorText) {
    traceColorText.addEventListener('change', () => {
      const val = traceColorText.value.trim();
      if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(val)) {
        state.traceColor = val.toUpperCase();
        syncColorInputs(state.traceColor, traceColorText, traceColorInput);
        markEdited();
        applyAll();
      }
    });
  }

  if (regenerateBlobBtn) {
    regenerateBlobBtn.addEventListener('click', () => {
      state.blobSeed = Math.floor(Math.random() * 1e9);
      markEdited();
      applyAll();
    });
  }

  if (paletteRefreshBtn) {
    paletteRefreshBtn.addEventListener('click', () => {
      refreshPalette();
    });
  }

  if (palettePickBtn) {
    palettePickBtn.addEventListener('click', () => {
      state.pickMode = !state.pickMode;
      palettePickBtn.classList.toggle('text-primary', state.pickMode);
      canvas.classList.toggle('cursor-crosshair', state.pickMode);
    });
  }

  if (customPaletteAddBtn) {
    customPaletteAddBtn.addEventListener('click', (event) => {
      if (requirePremium(event, labels.premiumTitlePalette)) return;
      const color = getCustomPaletteSourceColor();
      saveCustomPaletteColor(color);
    });
  }

  if (canvas) {
    canvas.addEventListener('mousemove', handleHover);
    canvas.addEventListener('mouseleave', clearHoverHighlight);
  }

  if (tabButtons.length) {
    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const name = btn.dataset.tab;
        if (name) setActiveTab(name);
      });
    });
    const initialTab = tabButtons[0]?.dataset.tab || 'colors';
    setActiveTab(initialTab);
  }

  if (undoBtn) {
    undoBtn.addEventListener('click', () => {
      if (historyIndex <= 0) return;
      historyIndex -= 1;
      restoreSnapshot(history[historyIndex]);
    });
  }

  if (redoBtn) {
    redoBtn.addEventListener('click', () => {
      if (historyIndex >= history.length - 1) return;
      historyIndex += 1;
      restoreSnapshot(history[historyIndex]);
    });
  }

  if (pickedColorInput) {
    pickedColorInput.addEventListener('input', () => {
      if (!state.pickedColor) return;
      const newColor = pickedColorInput.value.toUpperCase();
      replaceColor(state.pickedColor, newColor);
      setPickedColor(newColor);
      refreshPalette();
      markEdited();
      scheduleHistory();
    });
  }

  if (pickedTextInput) {
    pickedTextInput.addEventListener('change', () => {
      if (!state.pickedColor) return;
      const val = pickedTextInput.value.trim();
      if (/^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(val)) {
        const newColor = val.toUpperCase();
        replaceColor(state.pickedColor, newColor);
        setPickedColor(newColor);
        refreshPalette();
        markEdited();
        scheduleHistory();
      }
    });
  }

  if (presetsApplyBtn) {
    presetsApplyBtn.addEventListener('click', () => {
      const id = presetsSelect?.value;
      const preset = presets.find((p) => String(p.id) === String(id));
      if (preset) applyPreset(preset);
    });
  }

  if (presetsDeleteBtn) {
    presetsDeleteBtn.addEventListener('click', async () => {
      const id = presetsSelect?.value;
      if (!id) return;
      if (useLocalPresets) {
        presets = presets.filter((p) => String(p.id) !== String(id));
        writeLocalJson(localPresetsKey, presets);
        renderPresets();
        setPresetStatus(labels.presetsDeleted);
        return;
      }
      if (!presetsUrl) return;
      try {
        const res = await fetch(`${presetsUrl}/${id}`, {
          method: 'DELETE',
          headers: {
            'X-CSRF-TOKEN': csrfToken || '',
            'Accept': 'application/json'
          },
          credentials: 'same-origin'
        });
        if (!res.ok) throw new Error('delete');
        presets = presets.filter((p) => String(p.id) !== String(id));
        renderPresets();
        setPresetStatus(labels.presetsDeleted);
      } catch (e) {
        setPresetStatus(labels.presetsError);
      }
    });
  }

  if (presetsSaveBtn) {
    presetsSaveBtn.addEventListener('click', async (event) => {
      if (requirePremium(event, labels.premiumTitlePresets)) return;
      const name = (presetsNameInput?.value || '').trim();
      if (!name) {
        setPresetStatus(labels.presetsRequired);
        return;
      }
      if (useLocalPresets) {
        const existing = presets.findIndex((p) => (p.name || '').toLowerCase() === name.toLowerCase());
        const next = {
          id: existing >= 0 ? presets[existing].id : `local-${Date.now()}`,
          name,
          settings: getPresetPayload(),
        };
        if (existing >= 0) {
          presets[existing] = next;
        } else {
          presets.unshift(next);
        }
        writeLocalJson(localPresetsKey, presets);
        renderPresets();
        presetsSelect.value = String(next.id);
        setPresetStatus(labels.presetsSaved);
        return;
      }
      if (!presetsUrl) return;
      try {
        const res = await fetch(presetsUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-TOKEN': csrfToken || '',
            'Accept': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            name,
            settings: getPresetPayload()
          })
        });
        if (!res.ok) throw new Error('save');
        const data = await res.json();
        const preset = data.preset || data;
        const existing = presets.findIndex((p) => p.id === preset.id);
        if (existing >= 0) presets[existing] = preset; else presets.unshift(preset);
        renderPresets();
        presetsSelect.value = preset.id;
        setPresetStatus(labels.presetsSaved);
      } catch (e) {
        setPresetStatus(labels.presetsError);
      }
    });
  }

  if (presetsRefreshBtn) {
    presetsRefreshBtn.addEventListener('click', () => {
      loadPresets();
    });
  }

  resetBtn.addEventListener('click', () => {
    if (!originalSvg) return;
    const parsed = parseSvg(originalSvg);
    if (!parsed) return;
    if (historyTimer) {
      clearTimeout(historyTimer);
      historyTimer = null;
    }
    restoring = true;
    svgEl = parsed;
    svgEl.removeAttribute('width');
    svgEl.removeAttribute('height');
    svgEl.setAttribute('preserveAspectRatio', 'xMidYMid meet');
    if (stage) {
      stage.innerHTML = '';
      stage.appendChild(svgEl);
    }

    state.size = parseInt(sizeInput.defaultValue || '200', 10);
    state.padding = parseInt(paddingInput.defaultValue || '0', 10);
    state.stroke = parseInt(strokeInput.defaultValue || '0', 10);
    state.color = colorInput.defaultValue || '#000000';
    state.bg = bgInput.defaultValue || '#ffffff';
    state.useCurrentColor = currentColorInput?.defaultChecked || false;
    state.bgShape = 'none';
    state.bgPadding = parseInt(bgPaddingInput?.defaultValue || '0', 10);
    state.bgRadius = parseInt(bgRadiusInput?.defaultValue || '0', 10);
    state.traceWidth = parseInt(traceWidthInput?.defaultValue || '0', 10);
    state.traceColor = (traceColorInput?.defaultValue || '#0F172A').toUpperCase();
    state.applyGlobalColor = true;
    state.viewBox = state.baseViewBox ? { ...state.baseViewBox } : null;
    state.blobSeed = 0;
    state.flipX = false;
    state.flipY = false;
    state.rotate = 0;

    sizeInput.value = state.size;
    paddingInput.value = state.padding;
    strokeInput.value = state.stroke;
    syncColorInputs(state.color, colorText, colorInput);
    syncColorInputs(state.bg, bgText, bgInput);
    syncColorInputs(state.traceColor, traceColorText, traceColorInput);
    if (currentColorInput) currentColorInput.checked = state.useCurrentColor;
    if (bgPaddingInput) bgPaddingInput.value = state.bgPadding;
    if (bgRadiusInput) bgRadiusInput.value = state.bgRadius;
    if (traceWidthInput) traceWidthInput.value = state.traceWidth;
    updateShapeButtons();
    updateBgOptionsVisibility();

    window.requestAnimationFrame(() => {
      refreshPalette();
      if (state.palette.length === 1) {
        state.color = state.palette[0];
        syncColorInputs(state.color, colorText, colorInput);
      }
      state.applyGlobalColor = false;
      state.useCurrentColor = false;
      if (currentColorInput) currentColorInput.checked = false;
      applyAll();
      clearEdits();
      restoring = false;
      pushHistory(true);
    });
  });

  copyBtn.addEventListener('click', async (event) => {
    if (state.hasEdits && requirePremium(event, labels.premiumTitleCopySvg)) return;
    if (!svgEl) return;
    try {
      const serialized = state.hasEdits ? new XMLSerializer().serializeToString(svgEl) : (originalSvg || new XMLSerializer().serializeToString(svgEl));
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(serialized);
        if (copyLabel) copyLabel.textContent = labels.copied;
        setTimeout(() => { if (copyLabel) copyLabel.textContent = labels.copy; }, 1200);
        return;
      }
      throw new Error('clipboard');
    } catch (e) {
      try {
        const serialized = state.hasEdits ? new XMLSerializer().serializeToString(svgEl) : (originalSvg || new XMLSerializer().serializeToString(svgEl));
        const textarea = document.createElement('textarea');
        textarea.value = serialized;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        const ok = document.execCommand('copy');
        textarea.remove();
        if (copyLabel) copyLabel.textContent = ok ? labels.copied : labels.copyFailed;
        setTimeout(() => { if (copyLabel) copyLabel.textContent = labels.copy; }, 1200);
      } catch (err) {
        if (copyLabel) copyLabel.textContent = labels.copyFailed;
        setTimeout(() => { if (copyLabel) copyLabel.textContent = labels.copy; }, 1200);
      }
    }
  });

  downloadBtn.addEventListener('click', (event) => {
    if (state.hasEdits && requirePremium(event, labels.premiumTitleDownloadSvg)) return;
    if (!svgEl) return;
    const serialized = state.hasEdits ? new XMLSerializer().serializeToString(svgEl) : (originalSvg || new XMLSerializer().serializeToString(svgEl));
    const blob = new Blob([serialized], { type: 'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'icon-icons.svg';
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  });

  if (exportPngBtn) {
    exportPngBtn.addEventListener('click', () => {
      if (!svgEl) return;
      const serialized = new XMLSerializer().serializeToString(svgEl);
      const svgBlob = new Blob([serialized], { type: 'image/svg+xml;charset=utf-8' });
      const svgUrlObject = URL.createObjectURL(svgBlob);
      const img = new Image();

      img.onload = () => {
        const scale = 2;
        const size = Math.max(1, state.size);
        const output = Math.max(1, Math.round(size * scale));
        const canvasEl = document.createElement('canvas');
        canvasEl.width = output;
        canvasEl.height = output;
        const ctx = canvasEl.getContext('2d');

        if (ctx) {
          ctx.imageSmoothingEnabled = true;
          ctx.imageSmoothingQuality = 'high';
          if (state.bgShape === 'none' && state.bg && state.bg !== 'transparent') {
            ctx.fillStyle = state.bg;
            ctx.fillRect(0, 0, output, output);
          }
          ctx.drawImage(img, 0, 0, output, output);
          canvasEl.toBlob((pngBlob) => {
            if (!pngBlob) return;
            const pngUrl = URL.createObjectURL(pngBlob);
            const a = document.createElement('a');
            a.href = pngUrl;
            a.download = 'icon-icons.png';
            document.body.appendChild(a);
            a.click();
            a.remove();
            URL.revokeObjectURL(pngUrl);
          }, 'image/png');
        }

        URL.revokeObjectURL(svgUrlObject);
      };

      img.onerror = () => {
        URL.revokeObjectURL(svgUrlObject);
      };

      img.src = svgUrlObject;
    });
  }

  updateHistoryButtons();
  if (shouldAutoOpenEditor) {
    openModal();
  }
})();
</script>




      <script type="5a26d9c151509a424dfc2f05-text/javascript">
  (function(){
    const tryInit = () => {
