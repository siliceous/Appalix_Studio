                        aria-label="Save in your collection"
                        :aria-pressed="inCollection.toString()"
                        data-project-id="2429"
                        data-project-line-id="147325"
                        data-url-add="https://icon-icons.com/users-collections"
                        data-url-del="https://icon-icons.com/users-collections"
                        @click.stop.prevent="
                          $el.dataset.url = inCollection ? $el.dataset.urlDel : $el.dataset.urlAdd;
                          (inCollection ? $store.fav.deleteCollection($el) : $store.fav.collect($el))
                            .then(ok => { if (ok) inCollection = !inCollection })
                        "
                    >
                        
                        <svg x-cloak x-show="inCollection" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                             fill="currentColor" class="bi bi-bookmark-check-fill" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M2 15.5V2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.74.439L8 13.069l-5.26 2.87A.5.5 0 0 1 2 15.5m8.854-9.646a.5.5 0 0 0-.708-.708L7.5 7.793 6.354 6.646a.5.5 0 1 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0z"/>
                        </svg>

                        <svg x-cloak x-show="!inCollection" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
