                      By
            <a href="https://icon-icons.com/authors/941-gaurav-ghongde"
               class="font-bold text-gray-600">
               Gaurav Ghongde
            </a>
          
          
          <script type="5a26d9c151509a424dfc2f05-text/javascript">
// Copiar PNG / SVG (código o imagen/URL)
if (!window.__iiCopyDownloadInit) {
window.__iiCopyDownloadInit = true;
document.addEventListener('click', async function (e) {
    const btn = e.target.closest('[data-copy-url]');
    if (!btn) return;

    e.preventDefault();

    const url         = btn.getAttribute('data-copy-url');
    const fallbackUrl = btn.getAttribute('data-copy-fallback-url') || url;
    const type        = btn.getAttribute('data-copy-type') || 'url';
    if (!url) return;

    // Feedback visual: "Copied!" + ✔ y luego vuelve al texto original
    function markOk(target) {
        const originalHtml = target.getAttribute('data-original-html') || target.innerHTML;
        target.setAttribute('data-original-html', originalHtml);

        target.innerHTML = `
            <span class="flex items-center justify-center gap-2 w-full">
                <span>Copied!</span>
                <span>✔</span>
            </span>
        `;

        setTimeout(() => {
            target.innerHTML = originalHtml;
        }, 900);
    }

    // Copiar TEXTO aunque no haya navigator.clipboard (execCommand fallback)
    function copyTextFallback(text, target) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        try {
            document.execCommand('copy');
            markOk(target);
        } catch (err) {
            console.error('execCommand copy failed', err);
        } finally {
            document.body.removeChild(textarea);
        }
    }

    try {
        if (type === 'svg') {
            // 1) Obtenemos el código SVG de tu endpoint /raw/svg/{id}
            const res = await fetch(url, { credentials: 'omit' });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const text = await res.text();

            // 2) API moderna si existe
            if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(text);
                markOk(btn);
                return;
            }

            // 3) Fallback viejo: copiar código SVG como texto
            copyTextFallback(text, btn);
            return;
        }

        if (type === 'png') {
            // Intento "bonito": copiar la imagen como tal (solo funcionará en algunos navegadores/https)
            if (window.ClipboardItem && navigator.clipboard && navigator.clipboard.write) {
                try {
                    const res  = await fetch(url, { credentials: 'omit' });
                    if (res.ok) {
                        const blob = await res.blob();
                        const item = new ClipboardItem({ [blob.type]: blob });
                        await navigator.clipboard.write([item]);
                        markOk(btn);
                        return;
                    }
                } catch (err) {
                    console.warn('ClipboardItem PNG failed, falling back to URL', err);
                }
            }

            // Fallback estable: copiar la URL REAL de la imagen (fallbackUrl)
            if (navigator.clipboard && navigator.clipboard.writeText) {
                await navigator.clipboard.writeText(fallbackUrl);
                markOk(btn);
            } else {
                copyTextFallback(fallbackUrl, btn);
            }
            return;
        }

        // Cualquier otro tipo: copiar URL como texto
        if (navigator.clipboard && navigator.clipboard.writeText) {
            await navigator.clipboard.writeText(fallbackUrl);
            markOk(btn);
        } else {
            copyTextFallback(fallbackUrl, btn);
        }
    } catch (err) {
        console.error('Copy failed', err);
        // Último fallback: al menos intenta copiar la URL real
        copyTextFallback(fallbackUrl, btn);
    }
});
}
</script>

