          </div>

          <div class="svg-editor-tab-panel space-y-4 px-0 sm:px-1" data-tab-panel="colors">
            <div class="grid gap-3 lg:grid-cols-2">
              <div id="svg-editor-single-color" class="contents">
                <label class="text-xs font-semibold text-slate-600">Icon color</label>
                <div>
                  <button type="button" class="svg-editor-pickr h-12 w-12 cursor-pointer rounded border" data-pickr="svg-editor-color" aria-label="Icon color" style="background:#000000"></button>
                  <input id="svg-editor-color" type="hidden" value="#000000">
                </div>
              </div>

              <label class="text-xs font-semibold text-slate-600">Background</label>
              <div>
                <button type="button" class="svg-editor-pickr h-12 w-full cursor-pointer rounded border" data-pickr="svg-editor-bg" aria-label="Background" style="background:#ffffff"></button>
                <input id="svg-editor-bg" type="hidden" value="#ffffff">
              </div>
            </div>

            <div id="svg-editor-palette" class="rounded-xl border px-3 py-3">
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-slate-600">Colors</span>
              </div>
              <div id="svg-editor-palette-list" class="mt-2 grid py-4 px-2 max-h-48 grid-cols-5 gap-2 overflow-y-auto justify-items-start sm:grid-cols-6"></div>
              <p id="svg-editor-palette-empty" class="mt-2 text-[11px] text-slate-500 hidden">No colors detected.</p>
            </div>

            <div id="svg-editor-custom-palette" class="rounded-xl border px-3 py-3">
              <div class="flex items-center justify-between">
                <div class="relative flex items-center gap-2">
                  <span class="text-xs font-semibold text-slate-600">Custom palette</span>
                  <details class="relative">
                    <summary class="inline-flex h-5 w-5 cursor-pointer items-center justify-center rounded-full border text-[10px] font-bold text-slate-500 hover:text-slate-700"
                             style="list-style: none;">
                      i
                    </summary>
                    <div class="absolute left-0 top-full z-20 mt-2 w-64 rounded-xl border bg-white p-3 text-[11px] text-slate-600 shadow-lg">
                      Save frequently used colors to reuse them across icons with one click.
                    </div>
                  </details>
                </div>
                <button id="svg-editor-custom-add" type="button" aria-label="Add" class="inline-flex h-7 w-7 items-center justify-center rounded-md border text-sm font-semibold text-slate-600 hover:bg-slate-50">
                  +
                </button>
              </div>
              <div id="svg-editor-custom-list" class="mt-2 grid py-4 px-2 max-h-32 grid-cols-5 gap-2 overflow-y-auto justify-items-start sm:grid-cols-6"></div>
              <p id="svg-editor-custom-empty" class="mt-2 text-[11px] text-slate-500 hidden">No saved colors yet.</p>
              <p id="svg-editor-custom-status" class="mt-2 text-[11px] text-slate-500"></p>
            </div>
          </div>

          <div class="svg-editor-tab-panel space-y-4 px-0 sm:px-1 hidden" data-tab-panel="aspect">
            <div>
              <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                <span>Icon size</span>
                <span id="svg-editor-size-value">200px</span>
              </div>
              <input id="svg-editor-size" type="range" min="64" max="320" value="200" class="mt-2 w-full">
            </div>

            <div>
              <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                <span>Padding</span>
                <span id="svg-editor-padding-value">0%</span>
              </div>
              <input id="svg-editor-padding" type="range" min="0" max="200" value="0" class="mt-2 w-full">
            </div>

            <div>
              <div class="text-xs font-semibold text-slate-600">Flip / Mirror</div>
              <div class="mt-2 grid grid-cols-2 gap-2">
                <button id="svg-editor-flip-x" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">Horizontal</button>
                <button id="svg-editor-flip-y" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">Vertical</button>
              </div>
            </div>

            <div>
              <div class="text-xs font-semibold text-slate-600">Rotation</div>
              <div class="mt-2 grid grid-cols-2 gap-2">
                <button id="svg-editor-rotate-left" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">Rotate left</button>
                <button id="svg-editor-rotate-right" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">Rotate right</button>
              </div>
            </div>

          </div>

          <div class="svg-editor-tab-panel space-y-4 px-0 sm:px-1 hidden" data-tab-panel="shapes">
            <div>
              <div class="text-xs font-semibold text-slate-600">Shapes</div>
              <div class="mt-2 grid grid-cols-3 gap-2 sm:grid-cols-5">
                <button data-shape="none" class="svg-editor-shape rounded-lg border px-2 py-2 text-[11px] font-semibold text-slate-600 hover:bg-slate-50" title="None">
                  None
                </button>
                <button data-shape="square" class="svg-editor-shape rounded-lg border px-2 py-2 text-[11px] font-semibold text-slate-600 hover:bg-slate-50" aria-label="Square" title="Square">
                  <span class="mx-auto block h-4 w-4 rounded-sm border border-slate-500"></span>
                </button>
                <button data-shape="diamond" class="svg-editor-shape rounded-lg border px-2 py-2 text-[11px] font-semibold text-slate-600 hover:bg-slate-50" aria-label="Diamond" title="Diamond">
                  <span class="mx-auto block h-4 w-4 rotate-45 border border-slate-500"></span>
                </button>
                <button data-shape="circle" class="svg-editor-shape rounded-lg border px-2 py-2 text-[11px] font-semibold text-slate-600 hover:bg-slate-50" aria-label="Circle" title="Circle">
                  <span class="mx-auto block h-4 w-4 rounded-full border border-slate-500"></span>
                </button>
                <button data-shape="blob" class="svg-editor-shape rounded-lg border px-2 py-2 text-[11px] font-semibold text-slate-600 hover:bg-slate-50" aria-label="Blob" title="Blob">
                  <span class="mx-auto block h-4 w-4 rounded-[55%_45%_60%_40%/45%_55%_45%_55%] border border-slate-500"></span>
                </button>
              </div>
            </div>

            <div id="svg-editor-bg-options" class="space-y-3 hidden">
              <div>
                <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                  <span>BG padding</span>
                  <span id="svg-editor-bg-padding-value">0%</span>
                </div>
                <input id="svg-editor-bg-padding" type="range" min="0" max="40" value="0" class="mt-2 w-full">
              </div>
              <div id="svg-editor-bg-radius-group" class="hidden">
                <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                  <span>BG radius</span>
                  <span id="svg-editor-bg-radius-value">0%</span>
                </div>
                <input id="svg-editor-bg-radius" type="range" min="0" max="40" value="0" class="mt-2 w-full">
              </div>
              <button id="svg-editor-regenerate-blob" type="button" class="w-full rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                Regenerate blob
              </button>
            </div>
          </div>

          <div class="svg-editor-tab-panel space-y-4 px-0 sm:px-1 hidden" data-tab-panel="stroke">
            <div>
              <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                <span>Thickness</span>
                <span id="svg-editor-stroke-value">Auto</span>
              </div>
              <input id="svg-editor-stroke" type="range" min="0" max="10" value="0" class="mt-2 w-full">
            </div>

            <div>
              <div class="flex items-center justify-between text-xs font-semibold text-slate-600">
                <span>Trace width</span>
                <span id="svg-editor-trace-width-value">0</span>
              </div>
              <input id="svg-editor-trace-width" type="range" min="0" max="16" value="0" class="mt-2 w-full">
            </div>

            <div class="grid gap-2 lg:grid-cols-2">
              <label class="text-xs font-semibold text-slate-600">Trace color</label>
              <div class="flex items-center gap-2">
                <button type="button" class="svg-editor-pickr h-10 w-16 cursor-pointer rounded border" data-pickr="svg-editor-trace-color" aria-label="Trace color" style="background:#0f172a"></button>
                <input id="svg-editor-trace-color" type="hidden" value="#0f172a">
                <input id="svg-editor-trace-color-text" type="text" value="#0F172A" class="h-9 flex-1 rounded border px-2 text-xs uppercase">
              </div>
            </div>
          </div>

        </div>

        <div class="min-w-0 lg:col-start-1 lg:row-start-2">
          <div class="rounded-xl border bg-white p-3">
            <div class="flex items-center justify-between">
              <div class="relative flex items-center gap-2">
                <span class="text-xs font-semibold text-slate-600">Presets</span>
                <details class="relative">
                  <summary class="inline-flex h-5 w-5 cursor-pointer items-center justify-center rounded-full border text-[10px] font-bold text-slate-500 hover:text-slate-700"
                           style="list-style: none;">
                    i
                  </summary>
                  <div class="absolute left-0 top-full z-20 mt-2 w-64 rounded-xl border bg-white p-3 text-[11px] text-slate-600 shadow-lg">
                    Presets save your current editor settings (colors, background, padding, stroke, etc.) so you can apply them to other icons.
                  </div>
                </details>
              </div>
              <button id="svg-editor-refresh-presets" type="button" class="text-xs text-slate-500 hover:text-slate-700">↻</button>
            </div>
            <select id="svg-editor-presets" class="mt-2 w-full rounded-lg border px-2 py-2 text-xs">
              <option value="">Select a preset</option>
            </select>
            <div class="mt-2 grid grid-cols-1 gap-2 sm:grid-cols-2">
              <button id="svg-editor-apply-preset" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                Apply
              </button>
              <button id="svg-editor-delete-preset" class="rounded-lg border px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
                Delete
              </button>
            </div>
            <div class="mt-3 flex flex-col gap-2 sm:flex-row">
              <input id="svg-editor-preset-name" type="text" class="h-9 w-full flex-1 rounded-lg border px-2 text-xs" placeholder="Preset name">
              <button id="svg-editor-save-preset" class="h-9 w-full rounded-lg bg-slate-900 px-3 text-xs font-semibold text-white hover:bg-slate-800 sm:w-auto">
                Save
              </button>
            </div>
            <p id="svg-editor-preset-status" class="mt-2 text-[11px] text-slate-500"></p>
          </div>
        </div>
      </div>

      <div id="svg-editor-premium-modal" class="absolute inset-0 z-40 hidden flex items-center justify-center bg-black/50 p-4">
        <div class="relative flex w-full max-w-3xl overflow-hidden rounded-2xl bg-white shadow-2xl">
