</svg>
                </span>
                <span>Aspect</span>
              </button>
              <button type="button" class="svg-editor-tab flex w-full flex-col items-center justify-center gap-1 rounded-lg px-2 py-1.5 text-center hover:text-slate-700 sm:px-3 sm:py-2" data-tab="shapes">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-circle-square" viewBox="0 0 16 16">
