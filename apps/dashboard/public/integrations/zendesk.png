<style>
    .pcr-app {
      z-index: 1000400 !important;
    }
    #svg-editor-modal input[type="range"] {
      accent-color: var(--svg-editor-primary, #00c3ff);
    }
    #svg-editor-canvas .svg-editor-highlight {
      transition: filter 120ms ease;
    }
    #svg-editor-canvas:hover .svg-editor-highlight {
      filter: brightness(0.82);
    }
    #svg-editor-preview-panel {
      --svg-editor-preview-scale: 1;
    }
    #svg-editor-preview-panel #svg-editor-canvas,
    #svg-editor-preview-panel #svg-editor-stage {
      min-height: 320px;
      height: 320px;
      max-height: 320px;
    }
    #svg-editor-preview-panel svg {
      max-width: 100%;
      max-height: 100%;
      display: block;
    }
    @media (max-width: 1023px) {
      #svg-editor-preview-panel {
        --svg-editor-preview-scale: 0.6;
      }
      #svg-editor-preview-panel #svg-editor-canvas,
      #svg-editor-preview-panel #svg-editor-stage {
        min-height: 190px;
        height: 190px;
        max-height: 190px;
        overflow: hidden;
      }
      #svg-editor-preview-panel #svg-editor-stage {
        transform: scale(var(--svg-editor-preview-scale));
        transform-origin: center center;
      }
    }
  </style>
  <div id="svg-editor-modal"
       class="fixed inset-0 z-[1000200] hidden"
