        <div
        id="top-message"
        role="alert"
        class="fixed top-3 left-1/2 -translate-x-1/2 z-[1000600] hidden opacity-0 mx-auto rounded-md border border-slate-300 bg-slate-800 px-4 py-2 text-white shadow-lg transition-opacity duration-300"
