    <div class="relative mx-auto my-6 flex h-[90vh] w-[95%] max-w-5xl flex-col overflow-hidden rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b px-5 py-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-800">SVG Editor</h2>
          <p class="text-xs text-slate-500">Adjust color, background, padding and stroke.</p>
        </div>

          <button type="button" data-close class="inline-flex h-9 w-9 items-center justify-center rounded-full border text-slate-500 hover:text-slate-700">
            ✕
          </button>
        
      </div>

      <div class="flex-1 overflow-y-auto svg-editor-scroll">
      <div class="grid gap-6 p-4 sm:p-5 grid-cols-1 lg:grid-cols-[1.4fr,1fr]">
        <div class="contents lg:flex lg:min-w-0 lg:flex-col lg:gap-4 lg:col-start-1">
          <div class="flex flex-wrap items-center gap-2 mb-4 lg:mb-0">
          <button id="svg-editor-undo" type="button" class="rounded-full border bg-white px-3 py-1 text-[11px] font-semibold text-slate-600 shadow-sm hover:bg-slate-50">
            ↶ Undo
          </button>
          <button id="svg-editor-redo" type="button" class="rounded-full border bg-white px-3 py-1 text-[11px] font-semibold text-slate-600 shadow-sm hover:bg-slate-50">
            ↷ Redo
          </button>
          <button id="svg-editor-reset" type="button" class="rounded-full border bg-white px-3 py-1 text-[11px] font-semibold text-slate-600 shadow-sm hover:bg-slate-50">
           🗘 Reset
          </button>

        </div>
          <div id="svg-editor-preview-panel" class="sticky top-2 z-30 mb-4 rounded-xl border bg-white p-3 transition-transform duration-200 lg:static lg:z-auto lg:mb-0">
            <div id="svg-editor-canvas"
                 class="relative flex items-center justify-center rounded-lg"
                 style="--svg-editor-bg:#ffffff;background-color:var(--svg-editor-bg);background-image:radial-gradient(#e5e7eb 1px, transparent 1px);background-size:14px 14px;">
