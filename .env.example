# ============================================================
# Environment Variables — copy to .env.local for local dev
# NEVER commit real values to version control
# ============================================================

# ---------------------------------------------------------------
# Supabase (get from: https://supabase.com/dashboard/project/_/settings/api)
# ---------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # API backend only — never expose to browser

# Dashboard (Next.js — public vars)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ---------------------------------------------------------------
# Resend (transactional email — magic links)
# Get API key from: https://resend.com/api-keys
# Free tier: 100 emails/day, 3,000/month
# ---------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@yourdomain.com   # must be a verified domain in Resend (or use onboarding@resend.dev for testing)

# ---------------------------------------------------------------
# AI Providers
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # used for text-embedding-3-small

# ---------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ---------------------------------------------------------------
# WooCommerce Webhook (alternative billing path)
# ---------------------------------------------------------------
WOOCOMMERCE_WEBHOOK_SECRET=...

# ---------------------------------------------------------------
# Redis (Upstash — rate limiting & job queues)
# ---------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ---------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------
# Platform Integration Credentials
# (stored encrypted in integrations.config per workspace;
#  these are your platform app credentials, not per-tenant)
# ---------------------------------------------------------------

# Slack App (your platform-level Slack app)
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# Facebook / Meta
FACEBOOK_APP_ID=...
FACEBOOK_APP_SECRET=...

# Google Cloud (for Google Chat)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# WhatsApp Business (Meta)
WHATSAPP_APP_ID=...
WHATSAPP_APP_SECRET=...
